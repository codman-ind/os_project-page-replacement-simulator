<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#f0fdfa', 100: '#ccfbf1', 400: '#2dd4bf', 500: '#14b8a6', 600: '#0d9488', 900: '#134e4a' },
                        dark: { bg: '#0f172a', panel: '#1e293b', border: '#334155' }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-dark-bg text-slate-200 min-h-screen font-sans antialiased selection:bg-brand-500 selection:text-white">

    <%- include('partials/sidebar') %>

    <div class="md:pl-64 flex flex-col min-h-screen">
        <!-- Header -->
        <header class="border-b border-dark-border bg-dark-panel/50 backdrop-blur-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
                <div>
                    <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400">Workload Stress Test</h1>
                    <p class="text-xs text-slate-400 font-medium">Batch simulation across diverse memory access patterns</p>
                </div>
            </div>
        </header>

        <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
            
            <!-- Controls -->
            <section class="bg-dark-panel border border-dark-border rounded-2xl p-6 shadow-lg">
                <form action="/stress-test" method="GET" class="flex flex-col md:flex-row gap-4 items-end">
                    <div class="flex-1 w-full space-y-1.5">
                        <label class="text-sm font-medium text-slate-400">Frame Size</label>
                        <input type="number" name="frames" value="<%= inputs.frames %>" min="1" max="20" class="w-full bg-dark-bg border border-dark-border rounded-xl px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all text-sm">
                    </div>
                    <div class="flex-1 w-full space-y-1.5">
                        <label class="text-sm font-medium text-slate-400">Sequence Length</label>
                        <input type="number" name="length" value="<%= inputs.length %>" min="10" max="1000" class="w-full bg-dark-bg border border-dark-border rounded-xl px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all text-sm">
                    </div>
                    <div class="flex-1 w-full space-y-1.5">
                        <label class="text-sm font-medium text-slate-400">Simulation Runs</label>
                        <input type="number" name="runs" value="<%= inputs.runs %>" min="1" max="50" class="w-full bg-dark-bg border border-dark-border rounded-xl px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all text-sm">
                    </div>
                    <button type="submit" class="w-full md:w-auto bg-brand-600 hover:bg-brand-500 text-white font-medium py-2.5 px-6 rounded-xl shadow-lg transition-colors flex items-center justify-center space-x-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        <span>Run Batch</span>
                    </button>
                </form>
            </section>

            <!-- Results Table -->
            <section class="bg-dark-panel border border-dark-border rounded-2xl shadow-lg overflow-hidden">
                <div class="p-6 border-b border-dark-border">
                    <h2 class="text-lg font-semibold text-white">Performance Overview</h2>
                    <p class="text-sm text-slate-400">Average page faults across <%= inputs.runs %> runs of <%= inputs.length %> memory accesses.</p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-dark-bg/50 border-b border-dark-border">
                                <th class="py-4 px-6 font-semibold text-slate-300">Workload Pattern</th>
                                <th class="py-4 px-6 font-semibold text-slate-300">FIFO Faults</th>
                                <th class="py-4 px-6 font-semibold text-slate-300">LRU Faults</th>
                                <th class="py-4 px-6 font-semibold text-slate-300">Optimal Faults</th>
                                <th class="py-4 px-6 font-semibold text-slate-300">Best Practical Algorithm</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-border">
                            <% Object.keys(results).forEach(key => { const res = results[key]; %>
                                <tr class="hover:bg-dark-bg/30 transition-colors">
                                    <td class="py-4 px-6 font-medium text-white"><%= res.name %></td>
                                    <td class="py-4 px-6">
                                        <div class="flex flex-col">
                                            <span class="<%= res.fifo.faults == res.minFaults ? 'text-emerald-400 font-bold' : 'text-slate-300' %>">
                                                <%= res.fifo.faults %>
                                            </span>
                                            <span class="text-[10px] text-slate-500">Hit: <%= res.fifo.ratio %>%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <div class="flex flex-col">
                                            <span class="<%= res.lru.faults == res.minFaults ? 'text-emerald-400 font-bold' : 'text-slate-300' %>">
                                                <%= res.lru.faults %>
                                            </span>
                                            <span class="text-[10px] text-slate-500">Hit: <%= res.lru.ratio %>%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <div class="flex flex-col">
                                            <span class="<%= res.opt.faults == res.minFaults ? 'text-brand-400 font-bold' : 'text-slate-300' %>">
                                                <%= res.opt.faults %>
                                            </span>
                                            <span class="text-[10px] text-slate-500">Hit: <%= res.opt.ratio %>%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <% if (res.bestAlgo === 'Optimal') { %>
                                            <span class="px-2.5 py-1 bg-slate-500/20 text-slate-300 text-xs rounded-md font-medium">Optimal</span>
                                        <% } else if (res.bestAlgo.includes('Tie')) { %>
                                            <span class="px-2.5 py-1 bg-blue-500/20 text-blue-300 text-xs rounded-md font-medium"><%= res.bestAlgo %></span>
                                        <% } else { %>
                                            <span class="px-2.5 py-1 bg-emerald-500/20 text-emerald-400 text-xs rounded-md font-bold uppercase tracking-wide">
                                                <%= res.bestAlgo %>
                                            </span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Chart -->
            <section class="bg-dark-panel border border-dark-border rounded-2xl p-6 shadow-lg">
                <h2 class="text-lg font-semibold text-white mb-6">Algorithm Comparison by Workload</h2>
                <div class="h-[400px] w-full">
                    <canvas id="stressChart"></canvas>
                </div>
            </section>

            <!-- Pattern Definitions -->
            <section class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
                <div class="bg-dark-panel border border-dark-border rounded-2xl p-6">
                    <h3 class="text-sm font-bold text-sky-400 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span> Random Pattern
                    </h3>
                    <p class="text-xs text-slate-400 leading-relaxed">
                        Simulates a system with no predictable memory access. This is the ultimate test for algorithm robustness, as neither FIFO nor LRU can rely on history to predict the future. 
                    </p>
                </div>
                <div class="bg-dark-panel border border-dark-border rounded-2xl p-6">
                    <h3 class="text-sm font-bold text-violet-400 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span> Locality Pattern
                    </h3>
                    <p class="text-xs text-slate-400 leading-relaxed">
                        Mimics real-world software behavior where a program repeatedly accesses a small set of pages (like a loop). LRU typically excels here by keeping the "hot" pages in memory.
                    </p>
                </div>
                <div class="bg-dark-panel border border-dark-border rounded-2xl p-6">
                    <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Sequential Pattern
                    </h3>
                    <p class="text-xs text-slate-400 leading-relaxed">
                        Accesses pages in a strict 1-2-3-4 order. This pattern is the "worst-case" for LRU and FIFO when the sequence is larger than the number of frames, causing a fault on every single access.
                    </p>
                </div>
            </section>

        </main>
    </div>

    <!-- Prepare Chart Data -->
    <% 
        const labels = Object.keys(results).map(k => results[k].name);
        const fifoData = Object.keys(results).map(k => results[k].fifo.faults);
        const lruData = Object.keys(results).map(k => results[k].lru.faults);
        const optData = Object.keys(results).map(k => results[k].opt.faults);
    %>

    <script>
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.font.family = "'Outfit', sans-serif";

        const ctx = document.getElementById('stressChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: <%- JSON.stringify(labels) %>,
                datasets: [
                    {
                        label: 'FIFO Average Faults',
                        data: <%- JSON.stringify(fifoData) %>,
                        backgroundColor: 'rgba(14, 165, 233, 0.7)', // sky-500
                        borderColor: 'rgb(14, 165, 233)',
                        borderWidth: 1,
                        borderRadius: 4
                    },
                    {
                        label: 'LRU Average Faults',
                        data: <%- JSON.stringify(lruData) %>,
                        backgroundColor: 'rgba(139, 92, 246, 0.7)', // violet-500
                        borderColor: 'rgb(139, 92, 246)',
                        borderWidth: 1,
                        borderRadius: 4
                    },
                    {
                        label: 'Optimal Average Faults',
                        data: <%- JSON.stringify(optData) %>,
                        backgroundColor: 'rgba(16, 185, 129, 0.7)', // emerald-500
                        borderColor: 'rgb(16, 185, 129)',
                        borderWidth: 1,
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(51, 65, 85, 0.3)' },
                        title: { display: true, text: 'Average Page Faults' }
                    },
                    x: {
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        mode: 'index',
                        intersect: false
                    }
                }
            }
        });
    </script>
</body>
</html>
